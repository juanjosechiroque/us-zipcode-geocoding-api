#Environment
PORT=3000
NODE_ENV=development

#Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zipcodes

#Docker Compose (optional)
# Overrides the port Postgres is exposed on when running via docker compose.
POSTGRES_PORT=5432

#CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

#Reverse proxy
# Keep 0 when clients connect directly. Set to 1 only behind exactly one trusted proxy
# that overwrites X-Forwarded-* headers.
TRUST_PROXY_HOPS=0

#Rate Limiting (required in production)
# Applies per IP to /v1/locations only.
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_MAX=60

#Logging
LOG_LEVEL=info
