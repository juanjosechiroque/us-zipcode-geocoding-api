#Environment
PORT=3000
NODE_ENV=development

#Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zipcodes

#Docker Compose (optional)
# Overrides the port Postgres is exposed on when running via docker compose.
POSTGRES_PORT=5432

#CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

#Rate Limiting (optional — off by default, see ARCHITECTURE.md)
# Uncomment for the general-purpose limit (every route except search):
# RATE_LIMIT_WINDOW_MINUTES=1
# RATE_LIMIT_MAX=120

# Uncomment for the separate, more permissive limit on GET /v1/locations/search:
# SEARCH_RATE_LIMIT_WINDOW_SECONDS=10
# SEARCH_RATE_LIMIT_MAX=30

#Logging
LOG_LEVEL=info
